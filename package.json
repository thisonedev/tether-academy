{
  "name": "tether-academy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:webpack": "next dev",
    "dev:clean": "node scripts/dev-clean.mjs && next dev --turbopack",
    "prebuild": "npm run check:yaml && npm run sync:examples && npm run verify:tests:check",
    "build": "next build",
    "build:dev": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "format": "biome format --write .",
    "sync:examples": "node scripts/sync-examples.mjs",
    "sync:examples:check": "node scripts/sync-examples.mjs --check",
    "verify:tests": "node scripts/verify-tests.mjs",
    "verify:tests:check": "node scripts/verify-tests.mjs --check",
    "check:yaml": "node scripts/check-yaml.cjs"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@uiw/react-codemirror": "^4.25.10",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "fumadocs-core": "^15.0.0",
    "fumadocs-mdx": "13.0.0",
    "fumadocs-ui": "^15.0.0",
    "lucide-react": "^0.469.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/mdx": "^2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
